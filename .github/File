<script>
// ============================================================
//  EmailJS CONFIGURATION
//  Steps to activate automatic email sending:
//  1. Go to https://www.emailjs.com — create a free account
//  2. Add Email Service: connect your Outlook account
//     → Copy the Service ID (e.g. "service_xxxxxxx")
//  3. Create Email Template with these variables:
//     {{nombre}}  {{telefono}}  {{correo}}
//     {{servicios}}  {{descripcion}}  {{contacto}}
//     Set "To Email" to: Lcda.padillaortiz@outlook.com
//     → Copy the Template ID (e.g. "template_xxxxxxx")
//  4. Go to Account → API Keys → copy your Public Key
//  5. Replace the three values below and re-upload to GitHub
// ============================================================

var EJ_PUBLIC_KEY  = "YOUR_PUBLIC_KEY";   // replace
var EJ_SERVICE_ID  = "YOUR_SERVICE_ID";   // replace
var EJ_TEMPLATE_ID = "YOUR_TEMPLATE_ID";  // replace

var configured = (
  EJ_PUBLIC_KEY  !== "YOUR_PUBLIC_KEY" &&
  EJ_SERVICE_ID  !== "YOUR_SERVICE_ID" &&
  EJ_TEMPLATE_ID !== "YOUR_TEMPLATE_ID"
);

if (configured) {
  emailjs.init({ publicKey: EJ_PUBLIC_KEY });
} else {
  document.getElementById("setupBanner").style.display = "block";
}

// ── Helpers ──────────────────────────────────────────────
function showErr(id, show) {
  document.getElementById("e-" + id).style.display = show ? "block" : "none";
}
function markBad(el, bad) {
  if (bad) { el.classList.add("bad"); } else { el.classList.remove("bad"); }
}

// ── Submit ───────────────────────────────────────────────
document.getElementById("mainForm").addEventListener("submit", function(e) {
  e.preventDefault();

  var nombre   = document.getElementById("f-nombre");
  var telefono = document.getElementById("f-telefono");
  var correo   = document.getElementById("f-correo");
  var desc     = document.getElementById("f-desc");
  var svcChecked = document.querySelectorAll(".svc-cb:checked");
  var contacto   = document.querySelector(".rad-inp:checked");

  var ok = true;

  if (!nombre.value.trim()) {
    showErr("nombre", true); markBad(nombre, true); ok = false;
  } else { showErr("nombre", false); markBad(nombre, false); }

  if (!telefono.value.trim()) {
    showErr("telefono", true); markBad(telefono, true); ok = false;
  } else { showErr("telefono", false); markBad(telefono, false); }

  if (correo.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo.value.trim())) {
    showErr("correo", true); markBad(correo, true); ok = false;
  } else { showErr("correo", false); markBad(correo, false); }

  if (svcChecked.length === 0) {
    showErr("servicio", true); ok = false;
  } else { showErr("servicio", false); }

  if (!desc.value.trim()) {
    showErr("desc", true); markBad(desc, true); ok = false;
  } else { showErr("desc", false); markBad(desc, false); }

  if (!ok) return;

  var serviciosStr = Array.from(svcChecked).map(function(s){ return s.value; }).join(", ");
  var prefContacto = contacto ? contacto.value : "WhatsApp";
  var correoVal    = correo.value.trim() || "No proporcionado";

  var params = {
    to_email:   "Lcda.padillaortiz@outlook.com",
    nombre:     nombre.value.trim(),
    telefono:   telefono.value.trim(),
    correo:     correoVal,
    servicios:  serviciosStr,
    descripcion: desc.value.trim(),
    contacto:   prefContacto
  };

  var btn = document.getElementById("submitBtn");
  btn.disabled = true;
  btn.textContent = "Enviando…";

  if (!configured) {
    // Demo mode — show success without actually sending
    showSuccess(params);
    return;
  }

  emailjs.send(EJ_SERVICE_ID, EJ_TEMPLATE_ID, params)
    .then(function() {
      showSuccess(params);
    })
    .catch(function(err) {
      btn.disabled = false;
      btn.textContent = "Enviar Solicitud";
      alert("Error al enviar. Por favor llámenos al 787-690-9410.\n\nDetalle técnico: " + JSON.stringify(err));
    });
});

function showSuccess(p) {
  document.getElementById("mainForm").style.display = "none";
  document.getElementById("successBox").innerHTML =
    "<strong>Nombre:</strong> "      + p.nombre      + "<br>" +
    "<strong>Teléfono:</strong> "    + p.telefono    + "<br>" +
    "<strong>Correo:</strong> "      + p.correo      + "<br>" +
    "<strong>Área(s):</strong> "     + p.servicios   + "<br>" +
    "<strong>Contacto vía:</strong> "+ p.contacto;
  document.getElementById("successWrap").style.display = "block";
}
</script>

